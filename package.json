{
	"name": "@leftium/logo",
	"version": "0.1.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/Leftium/leftium-logo.git"
	},
	"homepage": "https://logo.leftium.com/",
	"license": "MIT",
	"scripts": {
		"robots": "bash scripts/update-robots.sh",
		"dev": "vite dev",
		"build": "vite build && npm run prepack",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && npx terser dist/webgl-ripples/webgl-ripples.js --compress --mangle --output dist/webgl-ripples/webgl-ripples.js && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"knip": "knip"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*",
		"!dist/webgl-ripples/webgl-ripples-original.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@leftium/nimble.css": "^0.13.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/culori": "^4.0.1",
		"@types/node": "^25.5.0",
		"jszip": "^3.10.1",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.16.0",
		"globals": "^17.4.0",
		"knip": "^6.1.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"publint": "^0.3.18",
		"svelte": "^5.55.1",
		"svelte-check": "^4.4.5",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.0",
		"vite": "^8.0.3"
	},
	"keywords": [
		"svelte"
	],
	"knip": {
		"ignoreExportsUsedInFile": true
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"dependencies": {
		"culori": "^4.0.2"
	}
}
